<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="x-apple-disable-message-reformatting">
    <title>Refund from {{ shop.name }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
      html, body { margin: 0 !important; padding: 0 !important; width: 100% !important; background-color: #FAF9F5; }
      * { -ms-text-size-adjust: 100%; -webkit-text-size-adjust: 100%; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      table { border-spacing: 0; border-collapse: collapse; }
      img { border: 0; outline: none; text-decoration: none; -ms-interpolation-mode: bicubic; }
      a { color: #1a1a1a; text-decoration: underline; }
      .serif { font-family: 'Cormorant Garamond', 'Bodoni Moda', 'Didot', 'Times New Roman', serif; }
      .sans  { font-family: 'Inter', 'Jost', 'Futura', 'Helvetica Neue', Arial, sans-serif; }
      @media only screen and (max-width: 620px) {
        .container { width: 100% !important; }
        .px { padding-left: 24px !important; padding-right: 24px !important; }
        .h1 { font-size: 32px !important; line-height: 38px !important; }
      }
    </style>
  </head>
  <body style="margin:0; padding:0; background-color:#FAF9F5;">
    <span style="display:none !important; visibility:hidden; opacity:0; color:transparent; height:0; width:0; font-size:1px; line-height:1px;">
      A refund has been issued for order {{ name }} — thank you for shopping with {{ shop.name }}.
    </span>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#FAF9F5;">
      <tr>
        <td align="center" style="padding: 40px 16px;">
          <table role="presentation" class="container" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px; max-width:600px; background-color:#FAF9F5;">

            <!-- Logo -->
            <tr>
              <td align="center" class="px" style="padding: 8px 40px 32px 40px;">
                {% if shop.email_logo_url %}
                  <img src="{{ shop.email_logo_url }}" alt="{{ shop.name }}" width="180" style="display:block; max-width:180px; height:auto;">
                {% else %}
                  <div class="serif" style="font-family:'Cormorant Garamond','Bodoni Moda','Didot','Times New Roman',serif; font-size:28px; letter-spacing:4px; color:#1a1a1a; text-transform:uppercase;">
                    {{ shop.name }}
                  </div>
                {% endif %}
              </td>
            </tr>

            <!-- Divider -->
            <tr><td style="padding: 0 40px;"><div style="border-top:1px solid #E5E2DA; height:1px; line-height:1px; font-size:1px;">&nbsp;</div></td></tr>

            <!-- Heading -->
            <tr>
              <td align="center" class="px" style="padding: 48px 40px 16px 40px;">
                <h1 class="serif h1" style="margin:0; font-family:'Cormorant Garamond','Bodoni Moda','Didot','Times New Roman',serif; font-weight:400; font-size:40px; line-height:46px; color:#1a1a1a; letter-spacing:0.5px;">
                  A refund has been issued
                </h1>
              </td>
            </tr>

            <!-- Intro -->
            <tr>
              <td align="center" class="px" style="padding: 16px 40px 8px 40px;">
                <p class="sans" style="margin:0; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:15px; line-height:24px; color:#4a4a4a; font-weight:300;">
                  {% if customer.first_name %}Dear {{ customer.first_name }},{% else %}Hello,{% endif %}
                </p>
                <p class="sans" style="margin:16px 0 0 0; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:15px; line-height:24px; color:#4a4a4a; font-weight:300;">
                  We have processed a refund for your order <strong style="color:#1a1a1a; font-weight:500;">{{ name }}</strong>. Details are below.
                </p>
              </td>
            </tr>

            <!-- Refund amount card -->
            <tr>
              <td align="center" class="px" style="padding: 32px 40px 8px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F2EFE7; border:1px solid #E5E2DA;">
                  <tr>
                    <td align="center" style="padding: 28px 24px;">
                      <div class="sans" style="font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:11px; letter-spacing:2.5px; color:#7a7a7a; text-transform:uppercase; font-weight:500;">
                        Amount Refunded
                      </div>
                      <div class="serif" style="margin-top:10px; font-family:'Cormorant Garamond','Bodoni Moda','Didot','Times New Roman',serif; font-size:36px; line-height:42px; color:#1a1a1a; font-weight:500;">
                        {{ amount | money }}
                      </div>
                      <div class="sans" style="margin-top:8px; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:13px; line-height:20px; color:#4a4a4a; font-weight:300;">
                        Refunded to your original payment method
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            {% if refund_line_items.size > 0 %}
            <!-- Refunded items -->
            <tr>
              <td class="px" style="padding: 40px 40px 8px 40px;">
                <div class="serif" style="font-family:'Cormorant Garamond','Bodoni Moda','Didot','Times New Roman',serif; font-size:22px; color:#1a1a1a; font-weight:500; letter-spacing:0.3px;">
                  Refunded items
                </div>
                <div style="border-top:1px solid #E5E2DA; margin-top:14px; height:1px; line-height:1px; font-size:1px;">&nbsp;</div>
              </td>
            </tr>

            {% for refund_line_item in refund_line_items %}
              {% assign line = refund_line_item.line_item %}
              <tr>
                <td class="px" style="padding: 18px 40px;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                      {% if line.image %}
                      <td valign="top" width="72" style="padding-right:18px;">
                        <img src="{{ line | img_url: 'compact_cropped' }}" alt="{{ line.title | escape }}" width="72" style="display:block; width:72px; height:auto; border:1px solid #E5E2DA;">
                      </td>
                      {% endif %}
                      <td valign="top">
                        <div class="sans" style="font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:14px; line-height:20px; color:#1a1a1a; font-weight:500;">
                          {{ line.title }}
                        </div>
                        {% if line.variant.title != 'Default Title' %}
                        <div class="sans" style="margin-top:4px; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:12px; line-height:18px; color:#7a7a7a; font-weight:300;">
                          {{ line.variant.title }}
                        </div>
                        {% endif %}
                        <div class="sans" style="margin-top:6px; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:12px; line-height:18px; color:#7a7a7a; font-weight:300;">
                          Quantity refunded: {{ refund_line_item.quantity }}
                        </div>
                      </td>
                      <td valign="top" align="right" class="sans" style="font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:14px; color:#1a1a1a; font-weight:500; white-space:nowrap; padding-left:12px;">
                        {{ line.price | times: refund_line_item.quantity | money }}
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            {% endfor %}
            {% endif %}

            <!-- View order button -->
            <tr>
              <td align="center" class="px" style="padding: 40px 40px 16px 40px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td align="center" style="background-color:#1a1a1a;">
                      <a href="{{ order_status_url }}" class="sans" style="display:inline-block; padding:16px 38px; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:12px; letter-spacing:2.5px; color:#FAF9F5; text-decoration:none; text-transform:uppercase; font-weight:500;">
                        View your order
                      </a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Help -->
            <tr>
              <td align="center" class="px" style="padding: 24px 40px 8px 40px;">
                <p class="sans" style="margin:0; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:13px; line-height:22px; color:#4a4a4a; font-weight:300;">
                  Refunds typically appear on your statement within 5–10 business days, depending on your bank or card issuer.
                </p>
              </td>
            </tr>

            <!-- Sign-off -->
            <tr>
              <td align="center" class="px" style="padding: 32px 40px 8px 40px;">
                <p class="sans" style="margin:0; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:14px; line-height:22px; color:#4a4a4a; font-weight:300;">
                  With thanks,
                </p>
                <p class="serif" style="margin:6px 0 0 0; font-family:'Cormorant Garamond','Bodoni Moda','Didot','Times New Roman',serif; font-size:20px; color:#1a1a1a; font-weight:500; letter-spacing:0.3px;">
                  {{ shop.name }}
                </p>
              </td>
            </tr>

            <!-- Footer divider -->
            <tr><td style="padding: 40px 40px 0 40px;"><div style="border-top:1px solid #E5E2DA; height:1px; line-height:1px; font-size:1px;">&nbsp;</div></td></tr>

            <!-- Footer -->
            <tr>
              <td align="center" class="px" style="padding: 24px 40px 8px 40px;">
                <p class="sans" style="margin:0; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:11px; line-height:18px; color:#7a7a7a; letter-spacing:1px; text-transform:uppercase; font-weight:400;">
                  {{ shop.name }}
                </p>
                <p class="sans" style="margin:8px 0 0 0; font-family:'Inter','Jost','Futura','Helvetica Neue',Arial,sans-serif; font-size:11px; line-height:18px; color:#9a9a9a; font-weight:300;">
                  If you have any questions, reply to this email or contact us at
                  <a href="mailto:{{ shop.email }}" style="color:#1a1a1a; text-decoration:underline;">{{ shop.email }}</a>.
                </p>
              </td>
            </tr>

            <tr><td style="padding: 24px 0;">&nbsp;</td></tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
