{% capture email_title %}A refund has been issued{% endcapture %}
{% capture email_body %}
Hi {{ customer.first_name }}, we have processed a refund for your order {{ name }}. Details are below.
{% endcapture %}

<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 4.0 Transitional//EN" "http://www.w3.org/TR/REC-html40/loose.dtd">
<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <title>{{ email_title }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Bodoni+Moda:wght@400;500;600&family=Inter:wght@300;400;500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
      html, body { margin: 0 !important; padding: 0 !important; width: 100% !important; }
      * { -ms-text-size-adjust: 100%; -webkit-text-size-adjust: 100%; }
      table { border-spacing: 0 !important; border-collapse: collapse !important; }
      img { border: 0; line-height: 100%; outline: none; text-decoration: none; -ms-interpolation-mode: bicubic; }

      body { background-color: #FAF9F5; font-family: 'Cormorant Garamond', 'Bodoni Moda', 'Didot', Georgia, 'Times New Roman', serif; color: #1a1a1a; }
      .wrap { width: 100%; background-color: #FAF9F5; }
      .container { width: 100%; max-width: 600px; margin: 0 auto; }
      .px { padding-left: 32px; padding-right: 32px; }

      .brand { text-align: center; padding: 40px 0 30px; }
      .brand img { display: inline-block; height: 32px; width: auto; max-width: 240px; }
      .divider { border: 0; border-top: 1px solid #e3ddd1; margin: 0; }
      h1.title { font-family: 'Cormorant Garamond', 'Bodoni Moda', 'Didot', Georgia, 'Times New Roman', serif; font-weight: 400; font-size: 26px; line-height: 1.25; color: #111; margin: 32px 0 12px; letter-spacing: 0.01em; }
      .order-meta { font-family: 'Inter', 'Jost', 'Futura', 'Avenir Next', Helvetica, Arial, sans-serif; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #7a7268; margin: 0 0 24px; }
      p.body { font-size: 15px; line-height: 24px; color: #2b2b2b; margin: 0 0 18px; }

      .btn-wrap { text-align: center; margin: 28px 0 8px; }
      .btn { background-color: #111111; color: #ffffff !important; text-decoration: none; display: inline-block; padding: 15px 36px; font-family: 'Inter', 'Jost', 'Futura', 'Avenir Next', Helvetica, Arial, sans-serif; font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; }
      .link { color: #111; text-decoration: underline; }

      .section-label { font-family: 'Inter', 'Jost', 'Futura', 'Avenir Next', Helvetica, Arial, sans-serif; font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase; color: #7a7268; margin: 32px 0 14px; }

      .li-title { font-family: 'Cormorant Garamond', 'Bodoni Moda', 'Didot', Georgia, serif; font-size: 15px; color: #111; margin: 0 0 4px; }
      .li-variant, .li-qty { font-family: 'Inter', 'Jost', 'Futura', 'Avenir Next', Helvetica, Arial, sans-serif; font-size: 12px; color: #7a7268; margin: 2px 0; }
      .li-price { font-family: 'Inter', 'Jost', 'Futura', 'Avenir Next', Helvetica, Arial, sans-serif; font-size: 14px; color: #111; text-align: right; white-space: nowrap; }

      .totals td { padding: 6px 0; font-family: 'Inter', 'Jost', 'Futura', 'Avenir Next', Helvetica, Arial, sans-serif; font-size: 13px; color: #2b2b2b; }
      .totals .label { color: #7a7268; }
      .totals .value { text-align: right; }
      .totals .grand td { padding-top: 14px; font-family: 'Cormorant Garamond', 'Bodoni Moda', 'Didot', Georgia, serif; font-size: 18px; color: #111; border-top: 1px solid #e3ddd1; }

      .footer { text-align: center; font-family: 'Inter', 'Jost', 'Futura', 'Avenir Next', Helvetica, Arial, sans-serif; font-size: 11px; letter-spacing: 0.1em; color: #9a9387; padding: 36px 24px 48px; }
      .footer a { color: #9a9387; text-decoration: underline; }

      @media only screen and (max-width: 600px) {
        .px { padding-left: 22px !important; padding-right: 22px !important; }
        h1.title { font-size: 22px !important; }
      }
    </style>
  </head>

  <body>
    <table class="wrap" role="presentation" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center">
          <table class="container" role="presentation" cellpadding="0" cellspacing="0" border="0">

            <tr><td class="brand"><img src="https://shop-happy-go-54.lovable.app/__l5e/assets-v1/94d40ec3-119f-40f4-a67e-27eac3ed3205/sellier-logo.png" alt="Sellier Knightsbridge" height="32"></td></tr>
            <tr><td><hr class="divider"></td></tr>

            <tr>
              <td class="px">
                <h1 class="title">{{ email_title }}</h1>
                <p class="order-meta">Order {{ name }} · {{ "now" | date: "%B %-d, %Y" }}</p>
                <p class="body">{{ email_body }}</p>

                {% if order_status_url %}
                  <div class="btn-wrap">
                    <a href="{{ order_status_url }}" class="btn">View your order</a>
                  </div>
                {% endif %}
              </td>
            </tr>

            <tr><td class="px"><hr class="divider" style="margin-top:20px;"></td></tr>

            <tr>
              <td class="px">
                <p class="section-label">Refund summary</p>
                <table role="presentation" class="totals" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr class="grand"><td>Amount refunded</td><td class="value">{{ amount | money_with_currency }}</td></tr>
                </table>
                <p class="body" style="margin-top:18px; font-size:13px; color:#7a7268;">
                  Refunded to your original payment method. Funds typically appear within 5–10 business days, depending on your bank or card issuer.
                </p>
              </td>
            </tr>

            {% if refund_line_items.size > 0 %}
              <tr><td class="px"><hr class="divider" style="margin-top:20px;"></td></tr>
              <tr>
                <td class="px">
                  <p class="section-label">Refunded items</p>
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                    {% for refund_line_item in refund_line_items %}
                      {% assign line = refund_line_item.line_item %}
                      <tr>
                        <td valign="top" style="padding:16px 0; border-bottom:1px solid #ede7da;">
                          {% if line.image %}
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                              <tr>
                                <td valign="top" width="72" style="padding-right:14px;">
                                  <img src="{{ line | img_url: 'compact_cropped' }}" width="64" alt="{{ line.title | escape }}" style="display:block;">
                                </td>
                                <td valign="top">
                                  <p class="li-title">{{ line.product.title | default: line.title }}</p>
                                  {% unless line.variant.title contains 'Default' %}
                                    <p class="li-variant">{{ line.variant.title }}</p>
                                  {% endunless %}
                                  <p class="li-qty">Qty refunded {{ refund_line_item.quantity }}</p>
                                </td>
                              </tr>
                            </table>
                          {% else %}
                            <p class="li-title">{{ line.product.title | default: line.title }}</p>
                            {% unless line.variant.title contains 'Default' %}
                              <p class="li-variant">{{ line.variant.title }}</p>
                            {% endunless %}
                            <p class="li-qty">Qty refunded {{ refund_line_item.quantity }}</p>
                          {% endif %}
                        </td>
                        <td valign="top" align="right" style="padding:16px 0; border-bottom:1px solid #ede7da;">
                          <span class="li-price">{{ line.price | times: refund_line_item.quantity | money }}</span>
                        </td>
                      </tr>
                    {% endfor %}
                  </table>
                </td>
              </tr>
            {% endif %}

            <tr>
              <td class="footer">
                SELLIER KNIGHTSBRIDGE<br>
                <a href="{{ shop.url }}">sellierknightsbridge.com</a><br><br>
                If you have any questions, reply to this email or contact us at
                <a href="mailto:{{ shop.email }}">{{ shop.email }}</a>.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
